model Seller {
  id          String  @id @default(uuid())
  userId      String  @unique
  shopName    String
  shopAddress String?
  shopPhone   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicines    Medicine[]
  sellerOrders SellerOrder[]

  @@index([shopName])
  @@map("seller_profiles")
}
